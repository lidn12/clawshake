{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName": "clawshake",
    "version": "0.1.0",
    "identifier": "com.clawshake.desktop",
    "build": {
        "frontendDist": "./dist"
    },
    "app": {
        "withGlobalTauri": true,
        "security": {
            "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; frame-src http://127.0.0.1:* http://localhost:*; connect-src ipc: http://tauri.localhost",
            "dangerousDisableAssetCspModification": true
        },
        "windows": []
    },
    "bundle": {
        "active": false,
        "icon": [
            "icons/icon.ico"
        ]
    }
}